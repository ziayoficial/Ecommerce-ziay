#!/bin/bash
set -e

# Run quick checks before allowing a commit
echo "🔍 Running pre-commit checks..."

# Type check (fast — uses cache)
npx tsc --noEmit --incremental 2>&1 | head -20
if [ $? -ne 0 ]; then
  echo "❌ TypeScript check failed"
  exit 1
fi

# Lint (only changed files for speed)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' | head -20)
if [ -n "$STAGED_FILES" ]; then
  bunx eslint $STAGED_FILES --rule '{"no-unused-vars": "error"}' 2>&1 | head -20
  if [ $? -ne 0 ]; then
    echo "⚠️  Lint warnings in staged files (non-blocking)"
  fi
fi

echo "✅ Pre-commit checks passed"
