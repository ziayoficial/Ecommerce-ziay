// ───────────────────────────────────────────────────────────────────────────
// 8. MONETIZATION (Saramantha §17) — commission over GMV
// ───────────────────────────────────────────────────────────────────────────
model CommissionEntry {
  id              String @id @default(cuid())
  tenantId        String
  orderId         String
  gmv             Float // order.total at confirmation
  comisionPct     Float // e.g. 4.5
  comisionTotal   Float // gmv * pct / 100
  reconocidaPct   Float @default(50) // 50 at "Datos completados", 100 at "Despachado"
  reconocidaMonto Float // comisionTotal * reconocidaPct / 100
  etapaReconocimiento String? // datos_completados | despachado
  reconocidaAt    DateTime?
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])

  // FIX-1-DB-001 — previously zero @@index (GMV aggregation joins).
  // `orderId @unique` closes the findFirst+update/create race in
  // /api/monetization/commission POST (two concurrent requests could both
  // pass findFirst==null and both create, leaving duplicate entries per order).
  @@unique([orderId])
  @@index([tenantId])
  @@index([etapaReconocimiento])
}

model Invoice {
  id              String @id @default(cuid())
  tenantId        String
  periodo         String // "2026-07"
  gmvTotal        Float
  feeBase         Float
  comisionTotal   Float
  tramoAplicado   String // "0-10M" | "10-40M" | "40M+"
  total           Float // feeBase + comisionTotal
  estado          String @default("borrador") // borrador | emitida | pagada
  emitidaAt       DateTime?
  pagadaAt        DateTime?
  createdAt       DateTime @default(now())

  // ── SPRINT-DIAN-RETRACTO-001 · P1-1 — DIAN electronic invoicing
  // (Decreto 745 de 2014). The existing fields above model the SaaS platform
  // billing invoice (commission over GMV per tenant per period — `periodo`
  // is the natural key). The fields below model the customer-facing DIAN
  // factura electrónica: each non-null `orderId` row is a separate invoice
  // for a customer's order. The two uses coexist on the same model —
  // platform-billing rows have `periodo` set + `orderId IS NULL`, while
  // DIAN customer-facing rows have `orderId` set + `periodo = ''`.
  // Future refactor: split into `PlatformInvoice` + `DianInvoice`.
  orderId          String? @unique // customer Order this DIAN invoice covers
  invoiceNumber    String? // consecutivo (e.g. "SETP-0001") — DIAN numeración
  cufe             String? // Código Único de Factura Electrónica (SHA-384)
  dianStatus       String? @default("pending") // "pending" | "pending_submission" | "accepted" | "rejected" | "error"
  dianValidationUrl String? // DIAN public validation URL (QR target)
  amount           Float? // total amount the invoice is for (DIAN total)
  issuedAt         DateTime? // when the DIAN invoice was generated
  metadata         String? // JSON — full DianInvoiceData payload for replay/PDF

  tenant Tenant @relation(fields: [tenantId], references: [id])
  // FIX-1-DB-001 — previously zero @@index (billing/invoicing queries).
  // Hot paths: tenant invoice list (tenantId), monthly period lookup
  // (tenantId + periodo), status funnel (estado), time series (createdAt).
  @@index([tenantId])
  @@index([tenantId, periodo])
  @@index([estado])
  @@index([createdAt])
  @@index([dianStatus])
}

