// ───────────────────────────────────────────────────────────────────────────
// 17. REMARKETING — abandoned cart, no-response, post-purchase flows
// ───────────────────────────────────────────────────────────────────────────

model RemarketingCampaign {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  trigger     String   // abandoned_cart | no_response | post_purchase
  template    String
  active      Boolean  @default(true)
