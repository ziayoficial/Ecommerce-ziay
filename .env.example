# ─────────────────────────────────────────────────────────────────────────────
# ZIAY · .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values before running the app:
#
#   cp .env.example .env
#
# Required-in-production vars are tagged `# REQUIRED in production`.
# Vars tagged `# Optional` work with sensible defaults; `# Dev only` are
# ignored in production. NEVER commit the real `.env` file to git.
#
# Generate strong secrets locally with:
#   openssl rand -base64 32   # NEXTAUTH_SECRET
#   openssl rand -hex 32      # ENCRYPTION_KEY (32 bytes → 64 hex chars)
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ────────────────────────────────────────────────────────────────────
# Next.js runtime mode — `development` or `production`. Auto-set by Next.
NODE_ENV=development

# Public canonical URL of the deployment (no trailing slash). Used for OG
# tags, JSON-LD, absolute redirects, and email links.
# REQUIRED in production.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Legacy alias of NEXT_PUBLIC_BASE_URL (kept for backward compat).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth.js canonical URL. Set to the same value as NEXT_PUBLIC_BASE_URL.
# REQUIRED in production.
NEXTAUTH_URL=http://localhost:3000

# NextAuth.js session/JWT signing secret. **REQUIRED in production.**
# Generate with: `openssl rand -base64 32`
NEXTAUTH_SECRET=

# At-rest AES-256-GCM encryption key for TOTP secrets + credential payloads
# (R-9). 64-char hex string preferred (32 bytes). Generate with:
#   `openssl rand -hex 32`
# Boot FAILS CLOSED in production if this is missing (S-10).
# REQUIRED in production.
ENCRYPTION_KEY=

# Prisma connection string. SQLite for dev, PostgreSQL for prod.
#   dev : file:./db/custom.db
#   prod: postgresql://USER:PASS@HOST:5432/DB?schema=public
# REQUIRED.
DATABASE_URL=file:./db/custom.db

# Default UI locale (es-CO / es-MX / pt-BR / …). Optional.
ZIAY_LOCALE=es-CO

# Build-time marker written by `next build` (do not set manually).
NEXT_BUILD_TIME=

# Next.js runtime — auto-set by the framework to `nodejs` or `edge`. Do not
# set this manually; documented here so it shows up in env-var audits.
# NEXT_RUNTIME=nodejs

# ── CORS / Cache / Rate Limit ───────────────────────────────────────────────
# Comma-separated allow-list for CORS origins (e.g. https://app.ziay.com).
# Empty = same-origin only. REQUIRED in production if API is called from a
# different origin.
CORS_ALLOWED_ORIGINS=

# Max entries for the in-memory LRU cache (default: 1000). Optional.
CACHE_MAX_ENTRIES=1000

# Redis URL for distributed rate-limit + queues. Optional in dev (falls back
# to in-memory). REQUIRED in production for multi-instance deploys.
REDIS_URL=

# Shared secret for cron-style internal endpoints (e.g. /api/cron/*). The
# caller must send `x-cron-secret: <CRON_SECRET>` header. REQUIRED in prod.
CRON_SECRET=

# ── Auth (OAuth providers — optional) ───────────────────────────────────────
# Uncomment and fill in if you wire Google / GitHub OAuth via NextAuth.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ── Chat / WebSocket Mini-Service ───────────────────────────────────────────
# Port for the standalone socket.io chat service (mini-services/chat-service).
CHAT_SERVICE_PORT=3003

# Internal URL the Next.js server uses to talk to the chat service directly.
CHAT_SERVICE_INTERNAL_URL=http://localhost:3003

# ── Payment Gateways ────────────────────────────────────────────────────────

# MercadoPago (LATAM)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_API_BASE=https://api.mercadopago.com
MERCADOPAGO_WEBHOOK_SECRET=
# Old secret kept during rotation windows for zero-downtime key rollover.
MERCADOPAGO_WEBHOOK_SECRET_OLD=

# Stripe (global)
STRIPE_SECRET_KEY=
STRIPE_API_BASE=https://api.stripe.com
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET_OLD=

# WOMPI (Colombia — Bancolombia)
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_API_BASE=https://production.wompi.co
WOMPI_EVENT_SECRET=
WOMPI_WEBHOOK_SECRET_OLD=

# PayU (LATAM)
PAYU_MERCHANT_ID=
PAYU_ACCOUNT_ID=
PAYU_API_KEY=
PAYU_API_LOGIN=
PAYU_API_BASE=https://api.payulatam.com
PAYU_DEFAULT_METHOD=
PAYU_NOTIFY_URL=
PAYU_PAYER_EMAIL=
PAYU_PAYER_IP=
PAYU_TEST_MODE=true
PAYU_WEBHOOK_SECRET=
PAYU_WEBHOOK_SECRET_OLD=

# Customer-facing redirect URLs after a payment attempt.
PAYMENT_RETURN_URL_SUCCESS=http://localhost:3000/payments/success
PAYMENT_RETURN_URL_PENDING=http://localhost:3000/payments/pending
PAYMENT_RETURN_URL_FAILURE=http://localhost:3000/payments/failure

# ── Local Payment Methods ───────────────────────────────────────────────────

# PSE — Colombia bank transfer
PSE_MERCHANT_ID=
PSE_API_KEY=
PSE_API_BASE=https://test.placetopay.com
PSE_WEBHOOK_SECRET=

# PIX — Brazil instant payment
PIX_PAYEE_KEY=
PIX_PAYEE_NAME=
PIX_HMAC_SECRET=
PIX_WEBHOOK_SECRET=
PIX_QR_IMAGE_ENDPOINT=
# Set to `true` if TLS is terminated at the load balancer (mTLS not on app).
PIX_MTLS_TERMINATED=false

# SPEI — Mexico bank transfer
SPEI_BANK_CODE=
SPEI_ACCOUNT_NUMBER=
SPEI_API_KEY=
SPEI_API_BASE=
SPEI_WEBHOOK_SECRET=

# Generic chargeback webhook shared secret (dedicated /api/webhooks/chargeback).
CHARGEBACK_WEBHOOK_SECRET=
CHARGEBACK_WEBHOOK_SECRET_OLD=

# ── WhatsApp / Meta ─────────────────────────────────────────────────────────
# Subscription handshake token for WhatsApp Cloud API webhooks. The Meta
# platform verifies ownership by sending `hub.verify_token` and expects this
# value back. Boot fails-closed in production if missing (S-12).
WA_VERIFY_TOKEN=

# Same handshake token for Meta (Messenger/Instagram) webhooks.
META_VERIFY_TOKEN=

# Meta app secret — used to verify `X-Hub-Signature-256` HMAC on incoming
# webhooks. REQUIRED in production if Meta webhooks are enabled.
META_APP_SECRET=

# WhatsApp Cloud API access token (graph API).
WHATSAPP_API_TOKEN=
WHATSAPP_CLOUD_API_BASE=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_CATALOG_ID=
WHATSAPP_CATALOG_API_BASE=https://graph.facebook.com/v18.0

# Meta Business Agent strategy — controls how Meta channel (WhatsApp /
# Messenger / Instagram) messages are routed (v0.4.3).
#   own_stack    → ZIAY agents handle everything (full control + tracing).
#   hybrid       → high-confidence intents to ZIAY agents, general chat to
#                  Meta's native Business Agent (cost optimization).
#   meta_native  → Meta handles everything (cheapest, least control).
# Default: own_stack. Optional.
META_AGENT_STRATEGY=own_stack

# ── NocoDB Integration ──────────────────────────────────────────────────────
# Shared secret for inbound NocoDB webhooks (/api/webhooks/nocodb-in).
# Boot fails-closed in production if missing (S-11).
NOCODB_WEBHOOK_SECRET=

# Outbound webhook URL (NocoDB → external). Optional.
NOCODB_WEBHOOK_URL=

# ── ERP / Fulfillment Integrations ──────────────────────────────────────────
# Alegra (LATAM invoicing/accounting)
ALEGRA_USERNAME=
ALEGRA_TOKEN=
ALEGRA_API_BASE=https://api.alegra.com/api/v1

# Dropi (Colombia dropshipping marketplace)
DROPI_API_KEY=
DROPI_API_BASE=https://api.dropi.co

# 99Envios (Colombia last-mile logistics)
NOVENTAYNUEVE_ENVIOS_API_BASE=https://api.99envios.com
# 99Envios API key — env var name has no leading digit (JS identifier rule);
# set `ENVIOS` and the lib reads it as the key.
ENVIOS=

# Aveonline (Colombia multi-carrier shipping)
AVEONLINE_API_KEY=
AVEONLINE_API_BASE=https://aveonline.co/api

# ── E-commerce Platform Integrations (optional) ─────────────────────────────
# Shopify
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_LOCATION_ID=
SHOPIFY_USE_GRAPHQL=true

# WooCommerce
WOOCOMMERCE_STORE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# Supabase (optional storage / auth helper)
SUPABASE_URL=
SUPABASE_API_KEY=

# ── DIAN (Colombia e-invoicing) ─────────────────────────────────────────────
# Software ID assigned by DIAN when registering the e-invoicing solution.
DIAN_SOFTWARE_ID=

# ── Ad Platforms (attribution / conversion APIs) ───────────────────────────
# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_ACCESS_TOKEN=
GOOGLE_ADS_API_BASE=https://googleads.googleapis.com/v14

# TikTok Ads / Events API
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_ADS_API_BASE=https://business-api.tiktok.com/open_api/v1.3
TIKTOK_EVENTS_API_BASE=https://business-api.tiktok.com/open_api/v1.3/event

# Facebook Pixel server-side API
FB_PIXEL_API_BASE=https://graph.facebook.com/v18.0
# FB_PIXEL_ID + FB_PIXEL_ACCESS_TOKEN (set if using server-side Pixel API)
# FB_PIXEL_ID=
# FB_PIXEL_ACCESS_TOKEN=

# Google Analytics 4 measurement ID (client-side). Optional.
GA=

# FX rates API base (used for multi-currency conversion). Optional.
FX_API_BASE=

# ── Anti-Fraud (OFAC sanctions screening) ───────────────────────────────────
# Optional — when set, calls the OFAC sanctions API; when empty, the service
# falls back to a local sanctions list bundled with the repo.
OFAC_API_KEY=

# Velocity / fraud thresholds (all OPTIONAL — sensible defaults baked in).
FRAUD_VELOCITY_IP_PER_MIN=20
FRAUD_VELOCITY_IP_HARD_CAP=100
FRAUD_VELOCITY_CUSTOMER_PER_MIN=10
FRAUD_VELOCITY_CUSTOMER_HARD_CAP=50
FRAUD_VELOCITY_DEVICE_PER_MIN=15
FRAUD_VELOCITY_DEVICE_HARD_CAP=75
FRAUD_VELOCITY_CARD_BIN_PER_MIN=10
FRAUD_VELOCITY_CARD_BIN_HARD_CAP=40
FRAUD_FIRST_PURCHASE_USD_THRESHOLD=500
# Comma-separated ISO-3166 alpha-2 country codes blocked outright.
FRAUD_SANCTIONED_COUNTRIES=CU,IR,KP,SY,

# ── LLM Providers (used by Saramantha agent layer) ─────────────────────────
# Which provider to default to: `openai` | `xai` | `ollama` | `auto`.
LLM_PROVIDER=auto

# OpenAI-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# xAI (Grok)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# Ollama (local LLM, dev only)
OLLAMA_BASE_URL=http://localhost:11434

# ── Monitoring / Observability ──────────────────────────────────────────────
# Sentry DSN (server + client). Empty = Sentry disabled. REQUIRED in prod
# if you want error/trace collection.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Sentry build-time release tag + auth (used by `@sentry/nextjs` webpack
# plugin to upload source maps). Optional.
SENTRY_RELEASE=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Pino log level: trace|debug|info|warn|error|fatal. Optional.
LOG_LEVEL=info

# Pino log shipping endpoint (HTTP POST per batch). Optional.
LOG_SHIPPING_URL=

# Alertmanager webhook shared secret (for inbound alert acknowledgements).
ALERTMANAGER_WEBHOOK_SECRET=

# Alert webhook (optional — Slack/Discord incoming webhook URL for operational
# alerts via `src/lib/alerts.ts` `sendAlert()`, v0.4.3). When set, operational
# events (circuit breaker open, Governor veto, pipeline failure, refund retry
# exhausted) are POSTed as JSON to this URL in addition to log + Sentry +
# socket.io. Empty = webhook channel disabled (other 3 channels still active).
# Examples:
#   Slack  : https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXX
#   Discord: https://discord.com/api/webhooks/000000000000000000/XXXXXXXX
ALERT_WEBHOOK_URL=

# ── Build / Bundle Analyser ─────────────────────────────────────────────────
# Set to `true` to enable `@next/bundle-analyzer` during `bun run build`.
ANALYZE=
