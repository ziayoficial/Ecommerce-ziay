// ───────────────────────────────────────────────────────────────────────────
// 17. AP2 / UCP / LEY 2573 / LEY 1581 — Agentic Protocols & Compliance
// (added by SPRINT-AGENTIC-PROTOCOLS-001 — audit AUDIT-AGENTIC-PROTOCOLS-001)
// Documento §9 (protocolos), §10 (AP2/UCP), §11 (gobernanza), §12 (regulacro CO).
// ───────────────────────────────────────────────────────────────────────────

/// AP2 Intent Mandate — lo que el usuario autorizó (W3C VC firmado).
/// Documento §10.2: "comprar zapatillas, talla 10, menos de $150".
/// Tres tipos encadenados: intent → cart → payment.
model AP2Mandate {
  id                String   @id @default(cuid())
  tenantId          String
  type              String   // "intent" | "cart" | "payment"
  parentMandateId   String?  // Cart enlaza a Intent; Payment enlaza a Cart
  userId            String?  // para Intent: quién autorizó
  // W3C Verifiable Credential payload (JSON serializado)
  vcPayload         String   // VC completo (incluye proof)
  vcSignature       String   // JWS / firma ed25519 (base64url)
  signatoryDid      String   // DID del firmante
  status            String   @default("active") // "active" | "revoked" | "consumed"
  revokedAt         DateTime?
  revokedReason     String?
  // Límites específicos del Intent (solo aplican a type=intent)
  maxAmount         Float?   // tope de gasto
  currency          String?  // "COP"
  categoryLimits    String?  // JSON: { "moda": 500000, "farmacia": 200000 }
  expiresAt         DateTime?
  // Recursos vinculados (para Cart / Payment)
  orderId           String?  // para Cart/Payment: order generado
  paymentRef        String?  // para Payment: referencia de pasarela
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant            Tenant       @relation(fields: [tenantId], references: [id])
  parentMandate     AP2Mandate?  @relation("MandateChain", fields: [parentMandateId], references: [id])
  childMandates     AP2Mandate[] @relation("MandateChain")

  @@index([tenantId, type, status])
  @@index([parentMandateId])
  @@index([userId])
  @@index([orderId])
  @@index([status, expiresAt])
}

/// UCP Checkout Session — máquina de estados:
/// incomplete → requires_escalation → ready_for_complete → completed/failed.
/// Documento §10.1.
model UcpCheckoutSession {
  id              String   @id @default(cuid())
  tenantId        String
  sessionId       String   @unique // ID externo compartido con el agente
  agentDid        String?  // DID del agente llamante
  intentMandateId String?  // enlace a AP2Mandate type=intent
  cartMandateId   String?  // enlace a AP2Mandate type=cart
  paymentMandateId String? // enlace a AP2Mandate type=payment
  state           String   @default("incomplete") // "incomplete" | "requires_escalation" | "ready_for_complete" | "completed" | "failed"
  cart            String?  // JSON: items, totals, shipping
  continuationUrl String?  // URL para escalamiento humano
  negotiatedCaps  String?  // JSON: capacidades intersecadas
  paymentHandler  String?  // "com.google.pay" | "com.stripe" etc
  orderId         String?  // una vez creado el order
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  expiresAt       DateTime?

  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, state])
  @@index([agentDid])
  @@index([orderId])
}

/// Verificación de identidad bajo Ley 2573 de 2026.
/// Documento §12.1: verificación trazable para crédito/cuotas; sin evidencia
/// la empresa asume el 100% de la pérdida ("carga dinámica de la prueba").
model IdentityVerification {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String?
  customerId      String?
  // Método de verificación
  method          String   // "kyc_provider" | "biometric" | "document" | "2fa_totp"
  provider        String?  // "onfido" | "jumio" | "local_bank" etc
  // Resultado
  status          String   @default("pending") // "pending" | "verified" | "failed" | "expired"
  verifiedAt      DateTime?
  expiresAt       DateTime? // KYC usualmente válido por N meses
  // Evidencia (hash, no datos crudos)
  evidenceHash    String?  // SHA-256 del bundle de evidencia
  evidenceUrl     String?  // URL de almacenamiento seguro
  // Contexto: qué transacción disparó esta verificación
  triggerType     String?  // "credit_purchase" | "installment_plan" | "high_value_order"
  triggerRef      String?  // order ID o mandate ID
  riskScore       Float?   // 0.0 - 1.0
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([userId])
  @@index([customerId])
  @@index([status, expiresAt])
}

/// Registro de consentimiento bajo Ley 1581 de 2012 (habeas data).
/// Documento §12.2: base legal + mecanismo de revocación.
model ConsentRecord {
  id              String   @id @default(cuid())
  tenantId        String
  dataSubjectId   String   // customer ID o user ID
  dataSubjectType String   // "customer" | "user" | "lead"
  // A qué se consintió
  purpose         String   // "marketing" | "analytics" | "ai_processing" | "data_sharing"
  legalBasis      String   // "consent" | "contract" | "legitimate_interest" | "legal_obligation"
  // Estado del consentimiento
  granted         Boolean  @default(true)
  grantedAt       DateTime @default(now())
  revokedAt       DateTime?
  revokeReason    String?
  // Evidencia
  proofHash       String?  // hash de prueba (IP, timestamp, UI version)
  proofPayload    String?  // JSON: { ip, userAgent, timestamp, uiVersion }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, dataSubjectId, purpose])
  @@index([dataSubjectType, granted])
  @@index([granted, revokedAt])
}

// ───────────────────────────────────────────────────────────────────────────
// SPRINT-FINANCE-META-001 — Channel cost tracking (study §14.1)
// "Costo operativo del canal (mensajería, agente de IA, logística)"
//
// One row per (tenant, channel, date). The date is stored as a DateTime at
// 00:00:00.000 local — SQLite has no native DATE type (and the schema stays
// portable to PostgreSQL where `@db.Date` could be re-added later). Use
// `recordDailyChannelCosts()` to upsert a day's row from operational data.
// ───────────────────────────────────────────────────────────────────────────
model ChannelCost {
  id            String   @id @default(cuid())
  tenantId      String
  channel       String   // "whatsapp" | "messenger" | "instagram" | "tiktok"
  date          DateTime // day bucket — stored at 00:00:00.000 local
  // Cost breakdown (study §14.1 — "costo operativo del canal")
  messageCost   Float    @default(0) // Meta message fees
  aiTokenCost   Float    @default(0) // LLM API costs
  adSpend       Float    @default(0) // ad spend attributed
  supportCost   Float    @default(0) // human agent time
  logisticsCost Float    @default(0) // shipping/logistics
  paymentFee    Float    @default(0) // payment gateway fees
  // Revenue
  revenue       Float    @default(0) // gross revenue from this channel
  ordersCount   Int      @default(0)
  // Computed (denormalized for fast dashboard reads)
  netContribution Float? // revenue - all costs
  marginPct       Float? // netContribution / revenue * 100
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, channel, date])
  @@index([tenantId, channel, date])
}

// ───────────────────────────────────────────────────────────────────────────
// 18. GOVERNANCE — DecisionLog (SPRINT-GOVERNANCE-001)
// Documento "Comercio Agéntico" §11 pilar #4: "Trazabilidad de decisiones".
// Cada llamada al agente genera una entrada aquí con input/output/reasoning
// + resultado de enforcement + responsabilidad determinada + revisión humana.
// ───────────────────────────────────────────────────────────────────────────

/// Full agent decision trace — document §11: "Trazabilidad de decisiones"
model DecisionLog {
  id            String   @id @default(cuid())
  tenantId      String
  agentName     String   // e.g. "cart_builder", "checkout"
  conversationId String?
  orderId       String?
  mandateId     String?  // AP2 mandate involved
  // Decision context
  input         String   // JSON: what the agent was asked
  output        String   // JSON: what the agent decided
  reasoning     String?  // JSON: chain-of-thought (if available)
  confidence    Float?   // 0.0 - 1.0
  // Enforcement outcome
  enforcementResult String? // JSON: { allowed, violations, escalated, blocked }
  liabilityParty    String? // "merchant_liability" | "agent_provider_liability" | etc
  // Human review
  humanReviewed     Boolean @default(false)
  humanDecision     String? // "approved" | "rejected" | "modified"
  humanReviewerId   String?
  humanReviewedAt   DateTime?
  // SPRINT-AI-LLM-ADAPTER-001 — tracking de tokens y costo por llamada LLM.
  // document §A-6 (tabla de costos en src/lib/llm/costs.ts).
  model             String?  // "glm-4.6", "gpt-4o", "grok-2-latest"
  provider          String?  // "zai", "openai", "xai", "ollama"
  promptTokens      Int?
  completionTokens  Int?
  totalTokens       Int?
  costUsd           Float?
  latencyMs         Int?
  createdAt         DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, agentName, createdAt])
  @@index([conversationId])
  @@index([orderId])
  @@index([mandateId])
  @@index([humanReviewed, createdAt])
}
