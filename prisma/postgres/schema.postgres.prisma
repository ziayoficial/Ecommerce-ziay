//      VolumePrice, SalesSpeech, Objection, ThemeDesign, CategoryCombo,
//      DeliveryHistory, ImageIdentification, AdPlatform, Campaign, Ad, AdSpend,
//      Attribution, Carrier, Shipment, CommissionEntry, Invoice,
//      AutomationRule, Setting, AuditLog — same as schema.prisma ...]
