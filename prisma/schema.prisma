// CommerceFlow OS — Prisma Schema (v2 · multi-tenant + Saramantha agents layer)
// Conversational Commerce + Ad Attribution + Multi-tenant Agent Platform
// Portable: SQLite (dev) -> PostgreSQL/MySQL + pgvector (prod).
// NOTE: SQLite has no native enums/arrays. We use String + constants in code.

// ───────────────────────────────────────────────────────────────────
// DATABASE PROVIDER — SQLite (dev) ↔ PostgreSQL (prod)
// ───────────────────────────────────────────────────────────────────
// The SAME schema compiles against either provider. To switch:
//
//   1. Edit the `datasource db` block below:
//        dev :  provider = "sqlite"      // DATABASE_URL=file:./db/custom.db
//        prod:  provider = "postgresql"  // DATABASE_URL=postgresql://...
//   2. Set `DATABASE_URL` accordingly (see `.env.example`).
//   3. Apply migrations:
//        dev :  bun run db:push
//        prod:  bun run db:migrate        // prisma migrate deploy
//   4. Seed:  bunx prisma db seed
//   5. SQLite → PostgreSQL data migration: use `pgloader` or a one-off
//      `prisma data proxy` snapshot (see PRODUCTION-CHECKLIST.md →
//      "PostgreSQL Migration" for the full step-by-step).
//
// Notes:
//   - SQLite has no native enums/arrays — we use String + constants in code.
//   - PostgreSQL-specific DDL (RLS policies, pgvector) lives in
//     `prisma/migrations/1_postgres_indexes/migration.sql` — only applied
//     when the provider is `postgresql`.
// ───────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

// SPRINT-DOCS-COMPLETE-001 — auto-generate an ERD (Entity Relationship
// Diagram) from the Prisma schema on every `prisma generate`. Output is a
// Mermaid-rendered SVG at `docs/erd.svg`. The path is relative to the
// `prisma/` directory (where schema.prisma lives), so `../docs/erd.svg`
// lands in the project's `docs/` folder. Requires `@mermaid-js/mermaid-cli`
// (mmdc) for SVG rendering — if mmdc is unavailable (no browser), the
// generator falls back to writing a `docs/erd.mmd` Mermaid source file that
// can be rendered manually via `bunx mmdc -i docs/erd.mmd -o docs/erd.svg`.
generator erd {
  provider = "prisma-erd-generator"
  output   = "../docs/erd.svg"
}

datasource db {
  // Dev: "sqlite"  ·  Prod: "postgresql"
  // (SPRINT7-POSTGRES-SERVICES-001 — keep dev on SQLite, switch only at deploy.)
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ───────────────────────────────────────────────────────────────────────────
// 0. TENANT (clientes_plataforma) — multi-tenant core
// ───────────────────────────────────────────────────────────────────────────
model Tenant {
  id                    String   @id @default(cuid())
  // slug used in URLs and as tenantId foreign key value (e.g. "saramantha")
  slug                  String   @unique
  nombreNegocio         String
  marca                 String
  // platform_catalogo: whatsapp_catalog | woocommerce | shopify | catalogo_propio_cliente | catalogo_nuestro
  plataformaCatalogo    String   @default("whatsapp_catalog")
  // bd_catalogo: supabase_cliente | supabase_nuestro | oracle_nuestro
  bdCatalogo            String?  @default("supabase_nuestro")
  credencialesCatalogoRef String? // ref to n8n/secret manager
  // proveedor_ia: chatgpt | xai | ollama | zai (default for this stack)
  proveedorIa           String   @default("zai")
  credencialesIaRef     String?
  // proveedor_logistico: dropi | 99envios | aveonline | otro
  proveedorLogistico    String   @default("dropi")
  credencialesLogisticaRef String?
  wabaId                String?
  wabaTokenRef          String?
  // brand config (regla de oro Saramantha §2: NO business data in prompts)
  tonoMarca             String?  // e.g. "tutea, certeza total, sin disculpas"
  nombreAsesora         String?  // e.g. "Sara"
  politicaPago          String?  // "híbrido: prepay 5% off > $250k, COD debajo"
  preguntaPerfil        String?  // "¿Para ti o para surtir tu negocio?"
  // plan_monetizacion: conecta | catalogo_incluido | completo
  planMonetizacion      String   @default("conecta")
  feeBaseMensual        Float    @default(0) // COP
  comisionPctInicial    Float    @default(4.5) // % over GMV (tramo 1)
  activo                Boolean  @default(true)
  // ── SPRINT-MULTICOUNTRY-001 — LATAM expansion (study §18) ──
  // ISO 3166-1 alpha-2 country code — drives currency, tax, and local payment
  // method availability (PSE/CO, PIX/BR, OXXO+SPEI/MX). Default CO (home market).
  countryCode           String   @default("CO")
  // ISO 4217 currency code — COP/MXN/BRL/USD/PEN/CLP/ARS. Default COP.
  currency              String   @default("COP")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  users                 User[]
  channels              Channel[]
  customers             Customer[]
  conversations         Conversation[]
  products              Product[]
  orders                Order[]
  campaigns             Campaign[]
  carriers              Carrier[] // tenant-scoped canonical carriers
  salesSpeeches         SalesSpeech[]
  objections            Objection[]
  themes                ThemeDesign[]
  categoryCombos        CategoryCombo[]
  volumePrices          VolumePrice[]
  deliveryHistories     DeliveryHistory[]
  shipments             Shipment[]
  commissionEntries     CommissionEntry[]
  invoices              Invoice[]
  auditLogs             AuditLog[]
  // ── AP2/UCP/Ley 2573/1581 — SPRINT-AGENTIC-PROTOCOLS-001 ──
  ap2Mandates            AP2Mandate[]
  ucpCheckoutSessions    UcpCheckoutSession[]
  identityVerifications  IdentityVerification[]
  consentRecords         ConsentRecord[]
  // ── SPRINT-FINANCE-META-001 — Channel cost tracking (study §14.1) ──
  channelCosts           ChannelCost[]
  // ── Governance — SPRINT-GOVERNANCE-001 ──
  decisionLogs           DecisionLog[]
  // ── SPRINT-SCHEMA-CLEANUP-001 — wire 30 orphan models (AUDIT-FINAL-ARCH-001) ──
  // Previously these 30 models carried a `tenantId` scalar + `@@index([tenantId])`
  // but no `tenant Tenant @relation(...)`, which broke cascade delete + Prisma
  // `include` traversal. Reverse relations grouped here for discoverability.
  messages               Message[]
  imageIdentifications   ImageIdentification[]
  customerScores         CustomerScore[]
  carrierScores          CarrierScore[]
  guideTrackings         GuideTracking[]
  guideMovements         GuideMovement[]
  buyerBehaviors         BuyerBehavior[]
  behaviorAlerts         BehaviorAlert[]
  conversationalCarts    ConversationalCart[]
  novedadCases           NovedadCase[]
  redeliveryRequests     RedeliveryRequest[]
  productEnrichments     ProductEnrichment[]
  traffickerCampaigns    TraffickerCampaign[]
  traffickerSales        TraffickerSale[]
  traffickerCompensations TraffickerCompensation[]
  marketplaceListings    MarketplaceListing[]
  leadShareConfig        LeadShareConfig? // 1:1 — tenantId is @unique on LeadShareConfig
  leadReferralsFrom      LeadReferral[]  @relation("LeadReferralFrom")
  leadReferralsTo        LeadReferral[]  @relation("LeadReferralTo")
  pixelConfigs           PixelConfig[]
  conversionEvents       ConversionEvent[]
  seoConfigs             SEOConfig[]
  geoTargets             GeoTarget[]
  remarketingCampaigns   RemarketingCampaign[]
  remarketingMessages    RemarketingMessage[]
  customerNotifications  CustomerNotification[]
  automationRules        AutomationRule[]   // tenantId is nullable on AutomationRule
  walletAccounts         WalletAccount[]    // tenantId is nullable on WalletAccount
  walletTransactions     WalletTransaction[] // tenantId is nullable on WalletTransaction
  withdrawalRequests     WithdrawalRequest[] // tenantId is nullable on WithdrawalRequest
  twoFactorConfigs       TwoFactorConfig?  // 1:1 — tenantId is @unique on TwoFactorConfig
}

// ───────────────────────────────────────────────────────────────────────────
// 1. IDENTITY & ACCESS
// ───────────────────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  // tenantId is optional: platform-level users (e.g. trafficker, finance, operator)
  // do not belong to a single tenant.
  tenantId  String?
  email     String   @unique
  name      String
  role      String   @default("agent") // admin | agent | trafficker | finance | operator | marketing
  avatarUrl String?
  // ── Auth (NextAuth v4 Credentials provider) ──
  passwordHash String?
  status       String   @default("active") // active | suspended | invited
  lastLoginAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant?          @relation(fields: [tenantId], references: [id])
  assignedConv  Conversation[]   @relation("AgentConvos")
  auditLogs     AuditLog[]

  // FIX-PEND-DB-QUEUES-001 — partial-index gap (AUDIT-GAP-4-DB).
  // Hot paths: tenant member list (tenantId), login lookup (email — already
  // @unique but explicit @@index follows the Trafficker.email convention).
  @@index([tenantId])
  @@index([email])
}

// ───────────────────────────────────────────────────────────────────────────
// 2. CHANNELS — WhatsApp (CO primary), Messenger (intl), Instagram DM
// ───────────────────────────────────────────────────────────────────────────
model Channel {
  id           String   @id @default(cuid())
  tenantId     String
  type         String   // whatsapp | messenger | instagram | telegram
  name         String   // e.g. "WhatsApp Colombia", "Messenger Global"
  displayName  String
  accountId    String?
  verified     Boolean  @default(false)
  active       Boolean  @default(true)
  country      String?  // ISO code this channel primarily serves
  paymentStrategy String @default("hybrid")
  requirePrepayMin  Float?
  prepayDiscountPct  Float? @default(0)
  codFee            Float?  @default(0)

  // ── Credenciales por tipo de canal (Saramantha §9.1, §9.2, §9.3) ──
  // WhatsApp Cloud API (§9.1)
  wabaId            String?  // WhatsApp Business Account ID
  phoneNumberId     String?  // Phone Number ID from Meta
  whatsappToken     String?  // Access token for WhatsApp Cloud API
  // Messenger (§9.2)
  pageId            String?  // Facebook Page ID
  pageAccessToken   String?  // Page Access Token
  // Instagram DM (§9.3)
  igAccountId       String?  // Instagram Business Account ID
  // Webhook security (all channels)
  verifyToken       String?  // Webhook verification token
  appSecret         String?  // App Secret for HMAC signature verification

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  conversations Conversation[]

  // FIX-PEND-DB-QUEUES-001 — partial-index gap (AUDIT-GAP-4-DB).
  // Hot paths: tenant channel list (tenantId), channel-type filtering
  // (whatsapp | messenger | instagram | telegram), active-only toggles.
  @@index([tenantId])
  @@index([type])
  @@index([active])
}

// ───────────────────────────────────────────────────────────────────────────
// 3. CUSTOMERS / CONTACTS
// ───────────────────────────────────────────────────────────────────────────
model Customer {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  phone       String?
  psid        String?
  igId        String?
  email       String?
  country     String?
  city        String?
  address     String?
  // Saramantha §2: perfil_detectado
  perfilDetectado String? // mayorista | emprendedor | detal | regalo
  notes       String?
  tags        String?
  lifetimeValue Float  @default(0)
  ordersCount  Int     @default(0)
  // FIX-LEGAL-P0-001 L-4 — Ley 1098 de 2006 (Código de la Infancia y
  // Adolescencia) Art 17. `birthDate` is set when KYC or the storefront
  // collects it; `isMinor` is a denormalized flag derived from `birthDate`
  // by `checkAgeGate()` so the consent / checkout gates don't have to
  // re-compute the age on every read. NULL `isMinor` means "unknown —
  // assume adult but flag for verification" (per the age-gate policy).
  birthDate         DateTime?
  isMinor           Boolean?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  conversations Conversation[]
  orders        Order[]

  // FIX-PEND-DB-QUEUES-001 — partial-index gap (AUDIT-GAP-4-DB).
  // Hot paths: tenant customer list (tenantId), email/phone customer lookup
  // (both fields are optional String? — indexing NULLs is cheap in PG/SQLite
  // and supports the customer-merge feature that finds dupes by phone/email).
  // FIX-LEGAL-P0-001 L-4 — `isMinor` index for fast lookup of minors.
  @@index([tenantId])
  @@index([email])
  @@index([phone])
  @@index([isMinor])
}

// ───────────────────────────────────────────────────────────────────────────
// 4. CONVERSATIONS & MESSAGES
// ───────────────────────────────────────────────────────────────────────────
model Conversation {
  id          String   @id @default(cuid())
  tenantId    String
  customerId  String
  channelId   String
  status      String   @default("open") // open | pending | resolved | closed
  priority    String   @default("normal")
  assigneeId  String?
  lastMessageAt DateTime @default(now())
  unreadCount Int      @default(0)
  sourceAdId      String?
  sourceCampaign  String?
  utm             String?
  // Saramantha §2: perfil determinado en la conversación
  perfilConversacion String? // mayorista | emprendedor | detal | regalo
  // SPRINT-WHATSAPP-FUNCTIONAL-001 — CTWA click_id capture + TTR tracking.
  // `clickId` stores the WhatsApp Click-to-WhatsApp-Ad (CTWA) click id
  // extracted from inbound message `context.referral.ctwa_click_id` /
  // `context.cta_url?cta_id=...`. Persisted at the conversation level so
  // orders created from this conversation inherit it for closed-loop CAPI
  // attribution (study §14.4).
  // `customerPhone` is a denormalized E.164 phone used by the WA webhook to
  // resolve or create a conversation by phone without first joining to
  // `Customer` (which may not exist yet for first-time leads).
  // `firstReplyAt` records the timestamp of the first outbound agent reply,
  // enabling First Response Time (TTR) analytics (study §14.4: conversion
  // drops >50% if no reply in 15–30 min).
  clickId          String?
  customerPhone    String?
  firstReplyAt     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant @relation(fields: [tenantId], references: [id])
  customer    Customer @relation(fields: [customerId], references: [id])
  channel     Channel  @relation(fields: [channelId], references: [id])
  assignee    User?    @relation("AgentConvos", fields: [assigneeId], references: [id])
  messages    Message[]
  orders      Order[]

  // FIX-1-DB-001 — previously zero @@index (most-read table in the app).
  // Hot paths: messenger inbox (tenantId + status + lastMessageAt DESC),
  // agent assignment dashboard (assigneeId), per-tenant scoping (tenantId).
  // SPRINT-WHATSAPP-FUNCTIONAL-001 — (tenantId, customerPhone, status) for
  // the WA webhook's open-conversation lookup by E.164 phone.
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, lastMessageAt])
  @@index([assigneeId])
  @@index([tenantId, customerPhone, status])
}

model Message {
  id             String   @id @default(cuid())
  tenantId       String
  conversationId String
  direction      String   // inbound | outbound
  body           String
  type           String   @default("text") // text | image | audio | template | order_card | payment_link
  mediaUrl       String?
  status         String   @default("sent")
  aiSuggested    Boolean  @default(false)
  aiConfidence   Float?
  // SPRINT-WHATSAPP-FUNCTIONAL-001 — WhatsApp Cloud API message ID for
  // deduplication of inbound webhooks (Meta retries up to ~24h) and for
  // `markMessageRead` calls. NULL for messages from channels without a
  // native message ID (e.g. simulated chat-service replies).
  waMessageId    String?
  // Saramantha §3: embedding for semantic memory (Bytes in SQLite, vector in PG)
  embedding      Bytes?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tenant        Tenant       @relation(fields: [tenantId], references: [id])

  // FIX-1-DB-001 — previously zero @@index (timeline + tenant isolation).
  // Hot paths: message timeline per conversation (conversationId + createdAt),
  // tenant-scoped scans (tenantId), sender-role analytics (direction).
  // SPRINT-WHATSAPP-FUNCTIONAL-001 — waMessageId index for inbound webhook
  // dedup queries (Meta retries up to ~24h).
  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([tenantId])
  @@index([direction])
  @@index([waMessageId])
}

// ───────────────────────────────────────────────────────────────────────────
// 5. CATALOG & ORDERS
// ───────────────────────────────────────────────────────────────────────────
model Product {
  id          String   @id @default(cuid())
  tenantId    String
  sku         String
  name        String
  description String?
  price       Float
  cost        Float    @default(0)
  imageUrl    String?
  stock       Int      @default(0)
  active      Boolean  @default(true)
  // Saramantha §2: design + theme
  diseno      String?  // e.g. "Stitch", "Hello Kitty"
  categoria   String?  // e.g. "familia", "short", "pantalon", "batola"
  // Saramantha §2: image with visible metadata stripe
  imagenMetadataVisible Boolean @default(true)
  fuenteSincronizacion  String? // whatsapp_catalog | woocommerce | shopify | supabase_cliente | supabase_nuestro | oracle_nuestro
  // ── SPRINT-MULTICOUNTRY-001 — LATAM expansion (study §18) ──
  // ISO 4217 currency code for the `price` field. Defaults to COP (home market).
  // A tenant's products can be priced in the tenant's `currency`.
  currency              String   @default("COP")
  // embeddings (Bytes in SQLite; in PG use vector type via Unsupported)
  embeddingTexto Bytes?
  embeddingVisual Bytes?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  orderItems  OrderItem[]
  volumePrices VolumePrice[]

  @@unique([tenantId, sku])

  // FIX-PEND-DB-QUEUES-001 — partial-index gap (AUDIT-GAP-4-DB).
  // The composite @@unique([tenantId, sku]) already serves (tenantId, sku)
  // and (tenantId) prefix queries, but an explicit @@index([tenantId]) keeps
  // the query planner honest for tenant-only product scans (catalog view).
  // `sku` alone is NOT indexed — cross-tenant sku lookups don't happen.
  @@index([tenantId])
}

model Order {
  id           String   @id @default(cuid())
  tenantId     String
  number       String   @unique
  customerId   String
  conversationId String?
  channelId    String?
  status       String   @default("new")
  // pending_payment | paid | preparing | shipped | delivered | returned | cancelled
  // Saramantha §10 Kanban: "Llamar para confirmar" | "Datos completados" | "Intento cancelación" | "Oficina" | "Programado" | "Despachado"
  paymentMode  String   // advance | cod | hybrid
  paymentStatus String  @default("unpaid")
  subtotal     Float
  discount     Float    @default(0)
  shipping     Float    @default(0)
  codFee       Float    @default(0)
  total        Float
  currency     String   @default("COP")
  // ── SPRINT-MULTICOUNTRY-001 — LATAM expansion (study §18) ──
  // ISO 3166-1 alpha-2 country code for this order's buyer (nullable for
  // legacy orders placed before the multi-country rollout). Drives the tax
  // computation — `taxBreakdown` JSON is the authoritative output of
  // `calculateTax()` for the order's items + shipping + countryCode.
  countryCode  String?
  taxAmount    Float    @default(0) // total tax (VAT/IGV/ICMS) charged on this order
  taxBreakdown String?  // JSON — full TaxBreakdown (subtotal, taxRate, exemptItems, ...)
  country      String?
  city         String?
  address      String?
  // Saramantha §2: imagen_referencia_url
  imagenReferenciaUrl String?
  // Saramantha §2: origen (CRITICAL for monetization §17.6)
  origen       String   @default("agente_whatsapp") // agente_whatsapp | carrito_web | otro
  sourceAdId       String?
  sourceCampaign   String?
  sourcePlatform   String?
  clickId          String?
  attributedAt     DateTime?
  paymentGateway   String?
  paymentRef       String?
  paidAt           DateTime?
  // ── SPRINT-DIAN-RETRACTO-001 · P1-2 — Derecho al retracto (Ley 1480 de
  // 2011 Art 47) — 5 calendar days cooling-off period for online purchases.
  // Set at order creation; `processRetracto()` enforces the window.
  retractoWindowUntil DateTime?
  // ── SPRINT-DIAN-RETRACTO-001 · cancellation metadata ──
  // `cancelReason` stores the consumer-supplied or system reason for the
  // cancellation (retracto, fraud, out-of-stock, etc.); `cancelledAt` is
  // the timestamp so retention + reporting can compute cancellation latency.
  cancelReason     String?
  cancelledAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  customer      Customer     @relation(fields: [customerId], references: [id])
  conversation  Conversation? @relation(fields: [conversationId], references: [id])
  sourceAd      Ad?           @relation(fields: [sourceAdId], references: [id])
  items         OrderItem[]
  events        OrderEvent[]
  shipments     Shipment[]
  commissionEntries CommissionEntry[]

  // FIX-1-DB-001 — previously zero @@index (KPIs, kanban, attribution, webhooks).
  // Hot paths: kanban (tenantId + status), KPI time series (tenantId + createdAt),
  // customer history (customerId), payment webhook lookup (paymentStatus).
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([customerId])
  @@index([paymentStatus])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  name      String
  unitPrice Float
  cost      Float
  quantity  Int
  diseno    String? // Saramantha: design variant per item

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  // FIX-1-DB-001 — previously zero @@index (every order detail + COGS calc).
  @@index([orderId])
  @@index([productId])
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  type      String   // created | paid | shipped | delivered | cancelled | refunded | cod_pending
  note      String?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // FIX-1-DB-001 — previously zero @@index (order audit timeline).
  // Hot paths: order event timeline (orderId + createdAt), event funnel (type).
  @@index([orderId])
  @@index([orderId, createdAt])
  @@index([type])
}

// ───────────────────────────────────────────────────────────────────────────
// 5.1 Saramantha §2 — pricing & discourse tables (per tenant)
// ───────────────────────────────────────────────────────────────────────────
model VolumePrice {
  id           String @id @default(cuid())
  tenantId     String
  productId    String
  sku          String // denormalized for convenience
  tipoCliente  String // mayorista | emprendedor | detal | regalo
  cantidadMinima Int
  cantidadMaxima Int
  precioUnitario Float

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([tenantId, productId, tipoCliente, cantidadMinima])
}

model SalesSpeech {
  id           String @id @default(cuid())
  tenantId     String
  perfil       String // mayorista | emprendedor | detal | regalo
  aperturaTexto String
  pruebaSocial String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, perfil])
}

model Objection {
  id           String @id @default(cuid())
  tenantId     String
  tipoObjecion String // desconfianza | precio | talla | lo_pienso | producto_no_disponible
  respuestaBase String
  gatilloMentalAsociado String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, tipoObjecion])
}

model ThemeDesign {
  id           String @id @default(cuid())
  tenantId     String
  tema         String // "Stitch", "Hello Kitty"
  nombreDiseno String?
  skusAsociados String // comma-separated SKUs (SQLite no arrays)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, tema])
}

model CategoryCombo {
  id           String @id @default(cuid())
  tenantId     String
  categoria    String // "familia", "short", etc.
  skusRecomendados String // comma-separated, min 3 distinct refs

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, categoria])
}

model DeliveryHistory {
  id           String @id @default(cuid())
  tenantId     String
  contactoId   String?
  direccionNormalizada String
  ciudad       String
  departamento String?
  resultadoEntregaAnterior String? // ok | rechazo | novedad

  tenant Tenant @relation(fields: [tenantId], references: [id])

  // SPRINT-SCHEMA-CLEANUP-001 — previously zero @@index (AUDIT-FINAL-ARCH-001).
  // Hot paths: tenant delivery history (tenantId), city distribution (ciudad),
