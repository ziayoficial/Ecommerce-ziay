  fromTenantId  String
  toTenantId    String
  customerPhone String
  customerName  String?
  reason        String
  commission    Float    @default(0)
  status        String   @default("pending") // pending | converted | expired
  createdAt     DateTime @default(now())

  fromTenant Tenant @relation("LeadReferralFrom", fields: [fromTenantId], references: [id])
  toTenant   Tenant @relation("LeadReferralTo", fields: [toTenantId], references: [id])

  @@index([fromTenantId])
  @@index([toTenantId])
